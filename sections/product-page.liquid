<section class="section-product-page">
  <div class="padding-global">
    <div class="container">

      <div class="product-info-breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/#perks">Perks</a>
        <span>/</span>
        {{ product.title | escape }}
      </div>

      <div class="product-page-grid">

        <!-- ── Gallery ── -->
        <div class="product-gallery">
          <div class="product-gallery-main">
            {% if product.featured_image %}
              <img id="product-main-img"
                   src="{{ product.featured_image | image_url: width: 1000 }}"
                   alt="{{ product.featured_image.alt | escape }}">
            {% endif %}
          </div>
        </div>

        <!-- ── Info ── -->
        <div class="product-info">

          <h1 class="product-info-name">{{ product.title }}</h1>

          <div class="product-info-prices">
            {% assign variant = product.variants.first %}
            {% if variant.compare_at_price > variant.price %}
              <span class="product-info-compare">{{ variant.compare_at_price | money_without_trailing_zeros }}</span>
            {% endif %}
            <span class="product-info-price">{{ variant.price | money_without_trailing_zeros }}</span>
          </div>

          <div class="product-info-badges">
            {% for tag in product.tags %}
              {% if tag contains 'left' %}
                <span class="product-info-badge orange">🔥 {{ tag }}</span>
              {% elsif tag contains 'Ships' or tag contains 'Aug' %}
                <span class="product-info-badge">🚚 {{ tag }}</span>
              {% elsif tag contains 'Worldwide' or tag contains 'world' %}
                <span class="product-info-badge">🌍 {{ tag }}</span>
              {% else %}
                <span class="product-info-badge">{{ tag }}</span>
              {% endif %}
            {% endfor %}
          </div>

          <div class="product-info-desc">
            {{ product.description }}
          </div>

          <!-- ── Add to Cart Form ── -->
          {% form 'product', product, id: 'product-form' %}
            <input type="hidden" name="id" value="{{ variant.id }}">

            <div class="product-form-qty-row">
              <span class="product-qty-label">Quantity</span>
              <div class="product-qty-input">
                <button type="button" class="product-qty-btn" onclick="adjustQty(-1)">−</button>
                <input type="number" name="quantity" id="qty-input" class="product-qty-number"
                       value="1" min="1" max="99" readonly>
                <button type="button" class="product-qty-btn" onclick="adjustQty(1)">+</button>
              </div>
            </div>

            <div class="product-form-actions">
              <button type="submit" name="add" class="btn-add-to-cart">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                Add to Cart
              </button>
              <a href="/checkout" class="btn-buy-now">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
                Buy Now
              </a>
            </div>

            <div class="product-secure-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              Checkout secured through Stripe
            </div>

          {% endform %}

          <hr class="product-info-divider">

          <!-- ── Product meta details ── -->
          <div>
            {% assign items_meta = product.metafields.custom.items_included %}
            {% assign delivery_meta = product.metafields.custom.estimated_delivery %}
            {% assign ships_meta = product.metafields.custom.ships_to %}
            {% assign stock_meta = product.metafields.custom.limited_quantity %}

            {% if stock_meta != blank %}
              <div class="product-detail-row">
                <span class="label">Availability</span>
                <span class="value urgent">{{ stock_meta }}</span>
              </div>
            {% endif %}

            {% if ships_meta != blank %}
              <div class="product-detail-row">
                <span class="label">Ships to</span>
                <span class="value">{{ ships_meta }}</span>
              </div>
            {% endif %}

            {% if delivery_meta != blank %}
              <div class="product-detail-row">
                <span class="label">Estimated delivery</span>
                <span class="value">{{ delivery_meta }}</span>
              </div>
            {% endif %}

            {% if items_meta != blank %}
              <div class="product-detail-row">
                <span class="label">Items included</span>
                <span class="value">{{ items_meta }}</span>
              </div>
            {% endif %}

            {%- comment -%} Fallback static rows when metafields not yet set {%- endcomment -%}
            {% if stock_meta == blank and ships_meta == blank %}
              <div class="product-detail-row">
                <span class="label">Ships to</span>
                <span class="value">Anywhere in the world</span>
              </div>
              <div class="product-detail-row">
                <span class="label">Estimated delivery</span>
                <span class="value">Aug 2026</span>
              </div>
            {% endif %}
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

{%- assign in_perks = false -%}
{%- for col in product.collections -%}
  {%- if col.handle == 'frontpage' -%}{%- assign in_perks = true -%}{%- endif -%}
{%- endfor -%}

{%- if in_perks -%}
  {%- assign addon_products = collections['perks'].products -%}
  {%- if addon_products.size > 0 -%}
<section class="section-products" style="padding-top:0;">
  <div class="padding-global">
    <div class="container">
      <div class="products-header">
        <h2 class="h-56">Power Up Your Setup</h2>
      </div>
      <div class="products-grid">
        {%- for ap in addon_products -%}
          {%- assign ap_price   = ap.variants.first.price -%}
          {%- assign ap_compare = ap.variants.first.compare_at_price -%}
          <div class="perk-card">
            <a href="{{ ap.url }}" class="perk-card-img-area" style="text-decoration:none;">
              {%- if ap.featured_image -%}
                <img class="perk-card-img"
                     src="{{ ap.featured_image | image_url: width: 800 }}"
                     alt="{{ ap.featured_image.alt | escape }}"
                     loading="lazy">
              {%- endif -%}
              <div class="perk-card-price-wrap">
                <span class="perk-card-price">{{ ap_price | money_without_trailing_zeros }}</span>
                {%- if ap_compare > ap_price -%}
                  <span class="perk-card-compare">{{ ap_compare | money_without_trailing_zeros }}</span>
                {%- endif -%}
              </div>
            </a>
            <div class="perk-card-body">
              <h3 class="perk-card-name">{{ ap.title }}</h3>
              <div class="perk-card-desc perk-card-desc--clamp">{{ ap.description }}</div>
              <div class="perk-card-footer">
                <div class="perk-card-buttons">
                  <form action="/cart/add" method="post">
                    <input type="hidden" name="id" value="{{ ap.variants.first.id }}">
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" class="perk-card-atc">
                      <span class="perk-card-atc-icon">+</span>
                      <span class="perk-card-atc-label">Add to Cart</span>
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>
  {%- endif -%}
{%- endif -%}

<script>
function adjustQty(delta) {
  const input = document.getElementById('qty-input');
  const newVal = Math.max(1, Math.min(99, parseInt(input.value || 1) + delta));
  input.value = newVal;
}

// Wire Buy Now to add to cart first then redirect
document.querySelector('.btn-buy-now').addEventListener('click', function(e) {
  e.preventDefault();
  const form = document.getElementById('product-form');
  const data = new FormData(form);
  data.append('return_to', '/checkout');
  fetch('/cart/add.js', { method: 'POST', body: data })
    .then(() => { window.location.href = '/checkout'; });
});
</script>

{% schema %}
{
  "name": "Product Page",
  "settings": []
}
{% endschema %}
