{% comment %}
  Reads from the "perks" collection. Create a collection with handle "perks" in Shopify admin
  and add all 7 products to it. The first product tag is used as the card label pill.
{% endcomment %}

<section class="section-products">
  <div class="padding-global">
    <div class="container">

      <div class="products-header">
        <h2 class="h-56">Select the Perk</h2>
      </div>

      <div class="products-grid">
        {% assign perks = collections['perks'].products %}
        {% if perks.size > 0 %}
          {% for product in perks %}
            {% assign tag_label = product.tags | first %}
            {% assign compare = product.variants.first.compare_at_price %}
            {% assign price   = product.variants.first.price %}
            <div class="perk-card">
              <a href="{{ product.url }}" style="display:contents; text-decoration:none;">
                <div class="perk-card-img-area">
                  {% if tag_label != blank %}
                    <span class="perk-card-tag">{{ tag_label }}</span>
                  {% endif %}
                  {% if product.featured_image %}
                    <img class="perk-card-img"
                         src="{{ product.featured_image | image_url: width: 800 }}"
                         alt="{{ product.featured_image.alt | escape }}"
                         loading="lazy">
                  {% endif %}
                  <div class="perk-card-prices">
                    {% if compare > price %}
                      <div class="perk-card-compare">{{ compare | money_without_trailing_zeros }}</div>
                    {% endif %}
                    <div class="perk-card-price">{{ price | money_without_trailing_zeros }}</div>
                  </div>
                </div>
              </a>

              <div class="perk-card-body">
                <a href="{{ product.url }}" style="text-decoration:none;">
                  <h3 class="perk-card-name">{{ product.title }}</h3>
                </a>
                <span class="perk-card-price-badge">{{ price | money_without_trailing_zeros }}</span>
                <div class="perk-card-desc">{{ product.description }}</div>

                <div class="perk-card-footer">
                  <div class="perk-card-meta">
                    {% for tag in product.tags offset: 1 %}
                      {% if tag contains 'left' or tag contains 'Ships' or tag contains 'delivery' or tag contains 'Aug' %}
                        {% if tag contains 'left' %}
                          <span class="perk-meta-badge urgent">{{ tag }}</span>
                        {% else %}
                          <span class="perk-meta-badge">{{ tag }}</span>
                        {% endif %}
                      {% endif %}
                    {% endfor %}
                  </div>

                  <div class="perk-card-buttons">
                    <form action="/cart/add" method="post" style="display:contents;">
                      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                      <input type="hidden" name="quantity" value="1">
                      <button type="submit" class="perk-card-btn">Add to Cart</button>
                    </form>
                    <a href="{{ product.url }}" class="perk-card-view">View Product</a>
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}

