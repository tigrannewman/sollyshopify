<header class="navbar sticky-nav">
  <div class="padding-global">
    <div class="container">
      <nav class="navigation">
        <a aria-label="home" href="/" class="nav-logo-wrap w-inline-block">
          <img loading="lazy" src="https://cdn.prod.website-files.com/69c0dd041e48c15718e2d588/69c0e6f4e23263c9f8022b74_logo-solly.svg" alt="Solly" class="nav-logo">
        </a>
        <a href="/cart" class="nav-cart" aria-label="Cart">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          <span class="nav-cart-count" id="nav-cart-count"
                style="{{ cart.item_count | default: 0 | json | prepend: '' }}{% if cart.item_count == 0 %}display:none;{% endif %}">
            {{ cart.item_count }}
          </span>
        </a>
      </nav>
    </div>
  </div>
</header>

<style>
.sticky-nav {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  right: 0 !important;
  z-index: 200 !important;
  display: block !important;
}
.nav-cart {
  display: flex;
  align-items: center;
  position: relative;
  color: #fff;
  text-decoration: none;
  padding: 6px;
  border-radius: 8px;
  transition: color 0.2s ease;
}
.nav-cart:hover { color: #F8791F; }

.nav-cart-count {
  position: absolute;
  top: -2px;
  right: -4px;
  background: #F8791F;
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  min-width: 18px;
  height: 18px;
  border-radius: 100px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4px;
  line-height: 1;
}
</style>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
