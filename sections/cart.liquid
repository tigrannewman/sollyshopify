<section class="section-cart">
  <div class="padding-global">
    <div class="container">
      <div class="cart-page-wrap">

        <h1 class="h-48" style="margin-bottom:40px;">Your Cart</h1>

        {% if cart.item_count == 0 %}
          <div class="cart-empty">
            <p class="t-18" style="color:rgba(255,255,255,0.5);margin-bottom:32px;">Your cart is empty.</p>
            <a href="/" class="button w-inline-block"><div>Continue Shopping</div></a>
          </div>
        {% else %}
          <form action="/cart" method="post" id="cart-form">

            <div class="cart-items">
              {% for item in cart.items %}
                <div class="cart-item">
                  <div class="cart-item-img-wrap">
                    <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}">
                  </div>
                  <div class="cart-item-info">
                    <a href="{{ item.url }}" class="cart-item-title">{{ item.product.title }}</a>
                    {% unless item.variant.title == 'Default Title' %}
                      <div class="cart-item-variant">{{ item.variant.title }}</div>
                    {% endunless %}
                    <div class="cart-item-price">{{ item.final_price | money }}</div>
                  </div>
                  <div class="cart-item-qty">
                    <div class="product-qty-input">
                      <button type="button" class="product-qty-btn"
                              onclick="updateQty({{ item.index }}, {{ item.quantity | minus: 1 }})">−</button>
                      <input type="number" name="updates[]" value="{{ item.quantity }}"
                             min="0" class="product-qty-number" id="qty-{{ item.index }}">
                      <button type="button" class="product-qty-btn"
                              onclick="updateQty({{ item.index }}, {{ item.quantity | plus: 1 }})">+</button>
                    </div>
                  </div>
                  <div class="cart-item-total">{{ item.final_line_price | money }}</div>
                  <a href="/cart/change?line={{ item.index }}&quantity=0" class="cart-item-remove" title="Remove">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </a>
                </div>
              {% endfor %}
            </div>

            <div class="cart-footer">
              <div class="cart-totals">
                <div class="cart-total-row">
                  <span>Subtotal</span>
                  <span>{{ cart.total_price | money }}</span>
                </div>
                <div class="cart-total-note">Taxes and shipping calculated at checkout</div>
              </div>
              <div class="cart-actions">
                <button type="submit" name="update" class="btn-buy-now" style="width:100%;">Update Cart</button>
                <a href="/checkout" class="btn-add-to-cart" style="width:100%;text-decoration:none;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  Proceed to Checkout
                </a>
                <div class="product-secure-badge">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  Checkout secured through Stripe
                </div>
              </div>
            </div>

          </form>
        {% endif %}

      </div>
    </div>
  </div>
</section>

<style>
.cart-page-wrap { max-width: 860px; margin: 0 auto; }

.cart-empty { text-align: center; padding: 60px 0; }

.cart-items { display: flex; flex-direction: column; gap: 0; border-top: 1px solid rgba(255,255,255,0.08); }

.cart-item {
  display: grid;
  grid-template-columns: 80px 1fr auto auto auto;
  align-items: center;
  gap: 20px;
  padding: 20px 0;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
@media (max-width: 640px) {
  .cart-item { grid-template-columns: 64px 1fr auto; }
  .cart-item-qty, .cart-item-total { display: none; }
}

.cart-item-img-wrap {
  width: 80px; height: 80px;
  border-radius: 10px; overflow: hidden;
  background: #111; border: 1px solid rgba(255,255,255,0.07);
}
.cart-item-img-wrap img { width: 100%; height: 100%; object-fit: cover; }

.cart-item-title {
  font-size: 15px; font-weight: 600; color: #fff;
  text-decoration: none; display: block; margin-bottom: 4px;
}
.cart-item-title:hover { color: #F8791F; }
.cart-item-variant { font-size: 13px; color: rgba(255,255,255,0.4); margin-bottom: 4px; }
.cart-item-price { font-size: 14px; color: rgba(255,255,255,0.5); }

.cart-item-total { font-size: 16px; font-weight: 700; color: #fff; white-space: nowrap; }

.cart-item-remove {
  color: rgba(255,255,255,0.25); cursor: pointer;
  transition: color 0.15s; text-decoration: none;
  display: flex; align-items: center;
}
.cart-item-remove:hover { color: #ff5555; }

.cart-footer {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 40px;
  align-items: start;
  margin-top: 40px;
  padding-top: 32px;
  border-top: 1px solid rgba(255,255,255,0.08);
}
@media (max-width: 640px) {
  .cart-footer { grid-template-columns: 1fr; gap: 24px; }
}

.cart-total-row {
  display: flex; justify-content: space-between;
  font-size: 20px; font-weight: 700; color: #fff;
  margin-bottom: 8px;
}
.cart-total-note { font-size: 13px; color: rgba(255,255,255,0.35); }

.cart-actions { display: flex; flex-direction: column; gap: 10px; }
</style>

<script>
function updateQty(index, qty) {
  if (qty < 0) return;
  document.getElementById('qty-' + index).value = qty;
  document.getElementById('cart-form').submit();
}
</script>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
