<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ page_title }}</title>
  <meta name="description" content="{{ page_description | escape }}">

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
  {{ 'style.css' | asset_url | stylesheet_tag }}
  {{ 'product-cards.css' | asset_url | stylesheet_tag }}

  <style>
    body {
      padding-top: var(--nav-height);
    }
    * {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      -o-font-smoothing: antialiased;
    }
    /* FAQ accordion */
    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }
    .faq-item.is-open .faq-answer {
      max-height: 500px;
    }
  </style>

  <script src="{{ 'webfont.js' | asset_url }}"></script>
  <script>
    WebFont.load({ google: { families: ["Albert Sans:300,400,500,600,700"] } });
  </script>
  <script>
    !function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js",("ontouchstart"in o||o.DocumentTouch&&c instanceof DocumentTouch)&&(n.className+=t+"touch")}(window,document);
  </script>
</head>
<body>
  <div class="page-wrap">
    {{ content_for_layout }}
  </div>

  {{ 'jquery-3.5.1.min.js' | asset_url | script_tag }}
  {{ 'swiper-bundle.min.js' | asset_url | script_tag }}
  {{ 'webflow.schunk.js' | asset_url | script_tag }}
  {{ 'webflow.main.js' | asset_url | script_tag }}
  {{ 'theme.js' | asset_url | script_tag }}

  <!-- Sticky checkout bar — hidden on cart page -->
  <div id="checkout-bar" style="display:none;" {% if request.path == '/cart' %}data-hide-on-cart="true"{% endif %}>
    <a href="/checkout" id="checkout-bar-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      Proceed to Checkout
      <span id="checkout-bar-count"></span>
    </a>
  </div>

  <style>
    #checkout-bar {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 9999;
      animation: checkout-bar-in 0.3s ease;
    }
    @keyframes checkout-bar-in {
      from { opacity: 0; transform: translateX(-50%) translateY(12px); }
      to   { opacity: 1; transform: translateX(-50%) translateY(0); }
    }
    #checkout-bar-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      background: #F8791F;
      color: #fff;
      text-decoration: none;
      font-size: 1rem;
      font-weight: 700;
      padding: 0.875rem 2rem;
      border-radius: 100px;
      box-shadow: 0 8px 32px rgba(248,121,31,0.45);
      white-space: nowrap;
      transition: background 0.2s, box-shadow 0.2s;
    }
    #checkout-bar-btn:hover {
      background: #e06918;
      box-shadow: 0 8px 40px rgba(248,121,31,0.6);
    }
    #checkout-bar-count {
      background: rgba(255,255,255,0.25);
      border-radius: 100px;
      font-size: 0.8rem;
      font-weight: 700;
      padding: 2px 8px;
      min-width: 22px;
      text-align: center;
    }
    @media (max-width: 767px) {
      #checkout-bar {
        bottom: 1.25rem;
        width: calc(100% - 2.5rem);
        left: 1.25rem;
        right: 1.25rem;
        transform: none;
      }
      #checkout-bar-btn {
        width: 100%;
        justify-content: center;
        font-size: 1rem;
        padding: 1rem 1.5rem;
      }
    }
  </style>

  <script>
    (function () {
      var bar = document.getElementById('checkout-bar');
      var countEl = document.getElementById('checkout-bar-count');

      function showBar(count) {
        countEl.textContent = count;
        bar.style.display = 'block';
      }

      function hideBar() {
        bar.style.display = 'none';
      }

      function refreshCart() {
        fetch('/cart.js')
          .then(function(r) { return r.json(); })
          .then(function(cart) {
            if (cart.item_count > 0) {
              showBar(cart.item_count);
            } else {
              hideBar();
            }
          });
      }

      // Don't show on /cart page
      if (bar.dataset.hideOnCart) return;

      // Check on page load
      refreshCart();

      // Show after any add-to-cart
      document.addEventListener('cart:updated', function(e) {
        refreshCart();
      });

      // Hook into all ATC form submits and fetch-based adds
      document.addEventListener('submit', function(e) {
        var form = e.target;
        if (form && form.action && form.action.indexOf('/cart/add') !== -1) {
          setTimeout(refreshCart, 600);
        }
      }, true);

      // Expose globally so theme.js can call it after AJAX adds
      window.refreshCheckoutBar = refreshCart;
    })();
  </script>
</body>
</html>
